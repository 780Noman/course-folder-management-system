# Copy to .env and fill in real values. NEVER commit .env.
# In production set DJANGO_SETTINGS_MODULE=config.settings.prod, DEBUG off, and a
# long random SECRET_KEY (e.g. `python -c "import secrets;print(secrets.token_urlsafe(50))"`).
DJANGO_SETTINGS_MODULE=config.settings.dev
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL
DATABASE_URL=postgres://postgres:postgres@db:5432/coursefolders
# Used only by docker-compose.prod.yml's bundled Postgres (managed DBs ignore these)
POSTGRES_DB=coursefolders
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me

# Object storage (Cloudflare R2 / S3-compatible)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_ENDPOINT_URL=
AWS_S3_REGION_NAME=auto

# Email (SMTP — university account or Brevo free tier)
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=Course Folder System <no-reply@uiit.edu.pk>

# Uploads
MAX_UPLOAD_MB=100
# Lifetime (seconds) of signed URLs for private file downloads
SIGNED_URL_TTL=300

# PDF engine: auto (WeasyPrint, falls back to xhtml2pdf) | weasyprint | xhtml2pdf
PDF_ENGINE=auto

# HTTPS hardening (prod). Keep True behind a TLS proxy / on the cloud.
# Set False for an internal server reached over plain http://IP:8000.
ENABLE_HTTPS=True
# Needed for form POSTs over plain HTTP on an internal server (comma-separated),
# e.g. http://192.168.1.50:8000
CSRF_TRUSTED_ORIGINS=

# Gunicorn (production)
WEB_CONCURRENCY=3
GUNICORN_BIND=0.0.0.0:8000
GUNICORN_TIMEOUT=60

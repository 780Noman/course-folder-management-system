# Keep shell scripts and Dockerfiles LF so they run in Linux containers,
# regardless of the contributor's OS / core.autocrlf setting.
*.sh text eol=lf
docker/entrypoint.sh text eol=lf
Dockerfile text eol=lf
*.dockerfile text eol=lf

# Binary assets: never apply line-ending conversion
*.pdf binary
*.jpg binary
*.jpeg binary
*.png binary
*.docx binary
